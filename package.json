{
  "name": "samantha-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex-only Samantha control plane prototype",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "typecheck": "bun x tsc --noEmit",
    "test": "bun run test:portable",
    "test:portable": "bun run scripts/run-test-profile.ts portable",
    "test:host": "bun run scripts/run-test-profile.ts host",
    "test:all": "bun run scripts/run-test-profile.ts all",
    "verify:docs": "bun run scripts/verify-docs.ts",
    "verify:mac": "bun typecheck && bun run test:portable && bun run verify:docs",
    "verify:host": "bun typecheck && bun run test:all && bun run check:telegram-ux && bun run validate-fixture",
    "check:telegram-ux": "bun run scripts/check-telegram-ux.ts",
    "dispatch-worker": "bun run src/dispatch-worker.ts",
    "samantha": "bun run src/samantha.ts",
    "validate-fixture": "bun run src/index.ts validate-fixture"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.9.0"
  }
}
