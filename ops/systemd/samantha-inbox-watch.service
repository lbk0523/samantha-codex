[Unit]
Description=Samantha Codex inbox watcher
Documentation=https://github.com/lbk0523/samantha-codex

[Service]
Type=simple
WorkingDirectory=%h/projects/samantha-codex
ExecStart=%h/.bun/bin/bun run samantha inbox:watch
Restart=on-failure
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=15

[Install]
WantedBy=default.target
