[Unit]
Description=Samantha Codex approved action runner
Documentation=https://github.com/lbk0523/samantha-codex

[Service]
Type=simple
WorkingDirectory=%h/projects/samantha-codex
EnvironmentFile=-%h/projects/samantha-codex/.env
ExecStart=%h/.bun/bin/bun run samantha actions:watch --interval-ms=1000
Restart=on-failure
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=15

[Install]
WantedBy=default.target
