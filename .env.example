# Local Samantha-Codex environment.
# Copy to .env or point systemd EnvironmentFile at an existing local env file.
# Never commit real token values.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ALLOWED_SENDER_ID=
# TELEGRAM_REPLY_CHAT_ID=
# Required only if Telegram-approved dispatch actions should run.
# SAMANTHA_REPO_ROOT=/absolute/path/to/samantha-codex
# Required if codex is not available in the host service PATH.
# SAMANTHA_CODEX_BIN=/home/me/.nvm/versions/node/vX.Y.Z/bin/codex
# Optional when using local-only project profiles instead of references/project-profiles.
# SAMANTHA_PROJECT_PROFILES_DIR=$HOME/.config/samantha-codex/project-profiles
# Optional per-profile repo root overrides. Profile id is uppercased.
# SAMANTHA_PROJECT_OMHT_REPO_ROOT=$HOME/projects/oh-my-health-trainer
# SAMANTHA_PROJECT_SAMANTHA_REPO_ROOT=$HOME/projects/samantha-codex
# Optional for macOS launchd when Bun is installed somewhere else.
# SAMANTHA_BUN_BIN=$HOME/.bun/bin/bun
